APP_NAME=BiznisBox
APP_ENV=development
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
JWT_KEY=1234567890
JWT_ALGO=HS256

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=biznisbox
DB_USERNAME=biznisbox
DB_PASSWORD=biznisbox

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

MAIL_MAILER=sendmail
MAIL_SENDMAIL="/usr/sbin/sendmail -S mail:1025"
MAIL_FROM_ADDRESS=biznisbox@localhost
MAIL_FROM_NAME="${APP_NAME}"

# Sentry - logging (https://docs.sentry.io/platforms/php/laravel/)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_DSN_PUBLIC="${SENTRY_LARAVEL_DSN}"